# ─── ForecastAI Environment Variables (optional) ─────────────────────────────
# The preferred way to set database credentials is via config/config.yaml
# (database: section).  These env vars are a fallback when config.yaml is
# absent or the values are missing.
#
# Copy this file to .env to use it. DB_* variables are also read from the
# process environment (useful for Docker / cloud deployments).
#
# All other settings (auth, ETL source DB, logging, forecasting parameters,
# etc.) are stored in the database under Settings → System / Business Config.

# ── Target PostgreSQL (local working DB) ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=zcube
DB_SSLMODE=disable
